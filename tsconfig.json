{
  "compilerOptions": {
    "target": "ES2022",                            // More up-to-date than ES2020
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,     // Prevents casing issues on CI
    "strict": true,
    "skipLibCheck": true,                          // Speeds up build by skipping `.d.ts` checks
    "outDir": "dist",                              // Matches your build output path
    "rootDir": "src"                               // Ensures src layout is preserved
  },
  "include": ["src"]
}
